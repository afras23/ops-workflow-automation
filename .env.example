# ---------------------------------------------------------------
# Ops Workflow Automation — environment configuration
# Copy to .env and fill in values. Never commit .env to git.
# ---------------------------------------------------------------

# Application environment: development | test | production
APP_ENV=development

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ---------------------------------------------------------------
# AI Provider
# ---------------------------------------------------------------

# Provider to use: "mock" (no API calls) or "anthropic" (real Claude)
AI_PROVIDER=mock

# Anthropic API key — required when AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Claude model to use for extraction
AI_MODEL=claude-sonnet-4-6

# ---------------------------------------------------------------
# Cost Controls
# ---------------------------------------------------------------

# Maximum AI spend per calendar day in USD. Requests are refused
# once this limit is reached — the system degrades gracefully.
MAX_DAILY_COST_USD=10.0

# ---------------------------------------------------------------
# Routing Thresholds
# ---------------------------------------------------------------

# Items with confidence > this threshold are auto-approved
AUTO_APPROVE_THRESHOLD=0.85

# Items with confidence < this threshold are auto-rejected
AUTO_REJECT_THRESHOLD=0.50

# ---------------------------------------------------------------
# Storage
# ---------------------------------------------------------------

# SQLite database path (relative to project root)
SQLITE_PATH=data/app.db

# Mock CRM output paths
SHEETS_CSV_PATH=data/sheet_rows.csv
AIRTABLE_JSONL_PATH=data/airtable_rows.jsonl

# ---------------------------------------------------------------
# Integrations
# ---------------------------------------------------------------

# Slack incoming webhook URL for approval notifications.
# Leave blank to log summaries to stdout (safe for local dev).
SLACK_WEBHOOK_URL=

# ---------------------------------------------------------------
# Docker / PostgreSQL (for future storage migration)
# ---------------------------------------------------------------

API_PORT=8000
DB_NAME=opsworkflow
DB_USER=appuser
DB_PASSWORD=changeme
DB_PORT=5432
