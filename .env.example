# ---------------------------------------------------------------
# Ops Workflow Automation — environment configuration
# Copy to .env and fill in values. Never commit .env.
# ---------------------------------------------------------------

# Optional: Slack webhook URL for notifications.
# Leave blank to print summaries to console (safe for local dev).
SLACK_WEBHOOK_URL=

# Confidence threshold (0–1). Items below this score go to human review.
CONFIDENCE_THRESHOLD=0.78

# SQLite storage path (relative to project root).
# Mount this directory as a Docker volume for persistence.
SQLITE_PATH=data/app.db

# Mock output destinations
SHEETS_CSV_PATH=data/sheet_rows.csv
AIRTABLE_JSONL_PATH=data/airtable_rows.jsonl

# API port (used by docker-compose)
API_PORT=8000

# PostgreSQL (available via docker-compose for future storage migration)
DB_NAME=opsworkflow
DB_USER=appuser
DB_PASSWORD=changeme
DB_PORT=5432
