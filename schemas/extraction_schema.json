{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Extraction",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "request_type",
    "priority",
    "requester",
    "description",
    "line_items",
    "confidence",
    "extraction_notes"
  ],
  "properties": {
    "request_id": {
      "type": "string"
    },
    "request_type": {
      "type": "string",
      "enum": [
        "purchase_request",
        "customer_issue",
        "ops_change",
        "general_inquiry",
        "other"
      ]
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "urgent"
      ]
    },
    "due_date": {
      "type": [
        "string",
        "null"
      ]
    },
    "company": {
      "type": [
        "string",
        "null"
      ]
    },
    "requester": {
      "type": "object",
      "required": [
        "name",
        "email"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        }
      },
      "additionalProperties": false
    },
    "description": {
      "type": "string"
    },
    "line_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "item",
          "qty"
        ],
        "properties": {
          "item": {
            "type": "string"
          },
          "qty": {
            "type": "integer",
            "minimum": 1
          },
          "notes": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "extraction_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}

